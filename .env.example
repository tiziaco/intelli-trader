# iTrader environment surface — copy to .env and fill in real values.
# .env is gitignored; .env.example (this file) is committed. NEVER put real secrets here.

# Logging
ITRADER_LOG_LEVEL=INFO
ITRADER_JSON_LOGS=false
ITRADER_DISABLE_LOGS=false

# Results/operational Postgres store (component form — preferred)
ITRADER_DATABASE_HOST=localhost
ITRADER_DATABASE_PORT=5544
ITRADER_DATABASE_USER=postgres
ITRADER_DATABASE_NAME=itrader
ITRADER_DATABASE_PASSWORD=changeme
# ITRADER_DATABASE_URL=postgresql+psycopg2://user:pass@host:5544/itrader  # optional verbatim override

# Legacy D-live seams (separate, not the results store) — DOCUMENTED ONLY, not wired here
DATA_DB_URL=
SYSTEM_DB_URL=

# Exchange credentials (live only)
BINANCE_MAIN_API_KEY=
BINANCE_MAIN_API_SECRET=
BINANCE_SPOT_TESTNET_API_KEY=
BINANCE_SPOT_TESTNET_API_SECRET=
BINANCE_FUTURE_TESTNET_API_KEY=
BINANCE_FUTURE_TESTNET_API_SECRET=
OANDA_TESTNET_ACCOUNT_ID=
OANDA_TESTNET_API_KEY=
OANDA_TESTNET_API_SECRET=
